typedef struct XClosedCaptionProperties XClosedCaptionProperties;

struct XClosedCaptionProperties
{
    XColor BackgroundColor;
    XColor FontColor;
    XColor WindowColor;
    XClosedCaptionFontEdgeAttribute FontEdgeAttribute;
    XClosedCaptionFontStyle FontStyle;
    float FontScale;
    BOOLEAN Enabled;
};

