typedef struct XPersistentLocalStorageSpaceInfo XPersistentLocalStorageSpaceInfo;

struct XPersistentLocalStorageSpaceInfo
{
    UINT64 availableFreeBytes;
    UINT64 totalFreeBytes;
    UINT64 usedBytes;
    UINT64 totalBytes;
};

